# Supabase: Settings → Database → Connection string → URI (use direct, port 5432)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
SECRET_KEY=your-random-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
ALLOWED_ORIGINS=http://localhost:5173
# Public HTTPS URL of THIS backend — used to register Telegram bot webhooks for
# the interactive bot. e.g. https://track-it-backend.up.railway.app
# For local dev, point a tunnel (ngrok/cloudflared) at port 8000 and use its URL.
# Leave blank to keep Telegram outbound-only (reminders still work).
PUBLIC_BASE_URL=
